


@model Gestion_Usuarios.Models.StudentEditViewModel
@{
    ViewData["Title"] = "Registrar Alumno";
    var backUrl = Url.IsLocalUrl(Model.ReturnUrl)
        ? Model.ReturnUrl
        : Url.Action("Index", "Alumnos");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1 text-primary">
            <i class="fa-solid fa-user-plus me-2"></i>Registrar Alumno / Aspirante
        </h4>
        <p class="text-muted mb-0">Captura la información básica y asigna carrera y grupo cuando corresponda.</p>
    </div>
    <a href="@backUrl" class="btn btn-outline-secondary btn-sm">
        <i class="fa-solid fa-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" asp-controller="Alumnos" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            }

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Matricula" class="form-label"></label>
                    <input asp-for="Matricula" class="form-control" />
                    <span asp-validation-for="Matricula" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Folio" class="form-label"></label>
                    <input asp-for="Folio" class="form-control" />
                    <span asp-validation-for="Folio" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Nombres" class="form-label"></label>
                    <input asp-for="Nombres" class="form-control" />
                    <span asp-validation-for="Nombres" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="ApellidoPaterno" class="form-label"></label>
                    <input asp-for="ApellidoPaterno" class="form-control" />
                    <span asp-validation-for="ApellidoPaterno" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="ApellidoMaterno" class="form-label"></label>
                    <input asp-for="ApellidoMaterno" class="form-control" />
                    <span asp-validation-for="ApellidoMaterno" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="CURP" class="form-label"></label>
                    <input asp-for="CURP" class="form-control text-uppercase" maxlength="18" />
                    <span asp-validation-for="CURP" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="CareerId" class="form-label"></label>
                    <select asp-for="CareerId" class="form-select">
                        <option value="">Sin carrera</option>
                        @foreach (var item in Model.CareerOptions)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>
                    <span asp-validation-for="CareerId" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="GroupId" class="form-label"></label>
                    <select asp-for="GroupId" class="form-select">
                        <option value="">Sin grupo</option>
                        @foreach (var item in Model.GroupOptions)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>
                    <span asp-validation-for="GroupId" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a href="@backUrl" class="btn btn-light">Cancelar</a>
                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-plus me-1"></i>Registrar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
