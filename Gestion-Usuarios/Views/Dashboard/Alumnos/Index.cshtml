@model IEnumerable<Gestion_Usuarios.Models.StudentViewModel>
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Gestión de Alumnos";
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<div class="card shadow-sm">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 font-weight-bold text-primary">
            <i class="fa-solid fa-user-graduate me-2"></i>Listado de Alumnos
        </h5>
        <a href="@Url.Action("Create", "Alumnos")" class="btn btn-success btn-sm">
            <i class="fa-solid fa-plus me-1"></i> Nuevo Alumno
        </a>
    </div>
    <div class="card-body">
        <table id="miTabla" class="table table-striped table-hover dt-responsive nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>Matrícula / Folio</th>
                    <th>Nombre Completo</th>
                    <th>Carrera</th>
                    <th>Semestre</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr data-id="@item.Id">
                            <td>@item.Identificador</td>
                            <td>@item.NombreCompleto</td>
                            <td>@item.Carrera</td>
                            <td>
                                @if (item.Semestre.HasValue)
                                {
                                    <span class="badge bg-info">@item.Semestre ° Sem</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">N/A</span>
                                }
                            </td>
                            <td>
                                <span class="badge @item.EstadoBadgeClass">
                                    @item.EstadoCodigo
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-primary btn-sm" onclick="editarAlumno(@item.Id)" title="Editar">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                @if (item.EsActivo)
                                {
                                    <button class="btn btn-danger btn-sm" onclick="eliminarAlumno(@item.Id)" title="Dar de baja">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/datatables_tools.js"></script>
    <script>
        $(document).ready(function () {
            const options = {
                searchBuilder: true,
                colVis: true,
                colReorder: true
            };

            const dt = new DataTableInitializer(options);
            window.alumnosTable = dt.initialize('#miTabla', {
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.0.0/i18n/es-ES.json'
                }
            });
        });

        function editarAlumno(id) {
            if (!id || id <= 0) return;
            window.location.href = `@Url.Action("Edit", "Alumnos")/${id}`;
        }

        function eliminarAlumno(id) {
            if (!confirm('¿Deseas dar de baja al alumno seleccionado?')) return;

            fetch(`@Url.Action("Delete", "Alumnos")/${id}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': '@token' // Token de seguridad indispensable
                }
            }).then(r => {
                if (r.ok) {
                    const $row = $(`#miTabla tbody tr[data-id='${id}']`);
                    if ($row.length) {
                        // Cambiar estado visualmente
                        const $estadoCell = $row.find('td').eq(4);
                        $estadoCell.find('span').removeClass().addClass('badge bg-danger').text('BAJA');

                        // Deshabilitar botones
                        $row.find('.btn-danger').remove(); // Quitamos el botón de eliminar

                        if (window.alumnosTable) {
                            window.alumnosTable.row($row).invalidate().draw(false);
                        }
                    } else {
                        window.location.reload();
                    }
                } else {
                    alert('Error al procesar la solicitud.');
                }
            }).catch(err => alert('Error de conexión: ' + err.message));
        }
    </script>
}