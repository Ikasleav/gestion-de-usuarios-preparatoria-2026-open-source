@model IEnumerable<Gestion_Usuarios.Models.StudentViewModel>
@{
    ViewData["Title"] = "Histórico de Bajas";
}

<div class="card shadow-sm">
    <div class="card-header bg-white py-3">
        <h5 class="m-0 font-weight-bold text-danger">
            <i class="fa-solid fa-user-minus me-2"></i>Alumnos en Situación de Baja
        </h5>
    </div>
    <div class="card-body">
        <table id="miTablaBajas" class="table table-striped table-hover dt-responsive nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>Matrícula/Folio</th>
                    <th>Nombre Completo</th>
                    <th>CURP</th>
                    <th>Correo Electrónico</th>
                    <th>Carrera</th>
                    <th>Grupo</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Identificador</strong></td>
                            <td>@item.NombreCompleto</td>
                            <td><small class="text-muted">@item.CURP</small></td>
                            <td>@item.Email</td>
                            <td>@item.Carrera</td>
                            <td>@item.Grupo</td>
                            <td>
                                @* Usamos la propiedad centralizada en el modelo *@
                                <span class="badge @item.EstadoBadgeClass">
                                    @item.EstadoCodigo
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-outline-primary btn-sm" onclick="verAlumno(@item.Id)" title="Ver Detalles/Editar">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/datatables_tools.js"></script>
    <script>
        $(document).ready(function () {
            // Usamos la misma configuración estandarizada de DataTables
            $('#miTablaBajas').DataTable({
                responsive: true,
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.0.0/i18n/es-ES.json'
                },
                dom: 'Bfrtip',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        className: 'btn btn-success btn-sm',
                        text: '<i class="fa-solid fa-file-excel"></i> Excel'
                    },
                    {
                        extend: 'pdfHtml5',
                        className: 'btn btn-danger btn-sm',
                        text: '<i class="fa-solid fa-file-pdf"></i> PDF'
                    },
                    {
                        extend: 'print',
                        className: 'btn btn-dark btn-sm',
                        text: '<i class="fa-solid fa-print"></i> Imprimir'
                    }
                ]
            });
        });

        function verAlumno(id) {
            // Redirigimos al controlador de Alumnos ya que la edición es centralizada
            if (id) window.location.href = `@Url.Action("Edit", "Alumnos")/${id}`;
        }
    </script>
}