@model IEnumerable<Gestion_Usuarios.Models.StudentViewModel>
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Gestión de Nuevo Ingreso";
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 font-weight-bold text-primary">
            <i class="fa-solid fa-user-plus me-2"></i>Aspirantes - Nuevo Ingreso
        </h5>
        <a href="@Url.Action("Create", "Alumnos")" class="btn btn-success btn-sm">
            <i class="fa-solid fa-plus me-1"></i> Registrar Aspirante
        </a>
    </div>
    <div class="card-body">
        <table id="tablaNuevoIngreso" class="table table-striped table-hover dt-responsive nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>Folio</th>
                    <th>Nombre Completo</th>
                    <th>CURP</th>
                    <th>Correo Electrónico</th>
                    <th>Carrera</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr data-id="@item.Id">
                            <td><span class="badge bg-light text-dark border">@item.Identificador</span></td>
                            <td>@item.NombreCompleto</td>
                            <td><code class="text-dark">@item.CURP</code></td>
                            <td>@item.Email</td>
                            <td>@item.Carrera</td>
                            <td>
                                @* Usamos la lógica centralizada del modelo *@
                                <span class="badge @item.EstadoBadgeClass">
                                    @item.EstadoCodigo
                                </span>
                            </td>
                            <td class="text-center">
                                <button class="btn btn-outline-primary btn-sm" onclick="editarAlumno(@item.Id)" title="Editar">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" onclick="eliminarAlumno(@item.Id)"
                                        @(item.EstadoCodigo == "BAJA" ? "disabled" : "") title="Eliminar/Cancelar">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaNuevoIngreso').DataTable({
                responsive: true,
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/2.0.0/i18n/es-ES.json'
                },
                pageLength: 10,
                order: [[1, 'asc']]
            });
        });

        function editarAlumno(id) {
            window.location.href = `@Url.Action("Edit", "Alumnos")/${id}`;
        }

        function eliminarAlumno(id) {
            if (!confirm('¿Deseas cancelar el proceso de este aspirante?')) return;

            fetch(`@Url.Action("Delete", "Alumnos")/${id}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': '@token'
                }
            }).then(r => {
                if (r.ok) {
                    location.reload();
                } else {
                    alert('No se pudo procesar la baja.');
                }
            }).catch(err => alert('Error: ' + err.message));
        }
    </script>
}