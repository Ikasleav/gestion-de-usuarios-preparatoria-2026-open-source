@model Gestion_Usuarios.Models.DocenteEditViewModel
@{
    ViewData["Title"] = "Editar Docente";
    var backUrl = Url.IsLocalUrl(Model.ReturnUrl) ? Model.ReturnUrl : Url.Action("Index", "Docentes");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1 text-primary">
            <i class="fa-solid fa-user-pen me-2"></i>Editar Docente
        </h4>
        <p class="text-muted mb-0">Actualiza la informacion del docente seleccionado.</p>
    </div>
    <a href="@backUrl" class="btn btn-outline-secondary btn-sm">
        <i class="fa-solid fa-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" asp-controller="Docentes" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="PersonId" type="hidden" />
            <input asp-for="ReturnUrl" type="hidden" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            }

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="ApellidoPaterno" class="form-label"></label>
                    <input asp-for="ApellidoPaterno" class="form-control" />
                    <span asp-validation-for="ApellidoPaterno" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="ApellidoMaterno" class="form-label"></label>
                    <input asp-for="ApellidoMaterno" class="form-control" />
                    <span asp-validation-for="ApellidoMaterno" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Telefono" class="form-label"></label>
                    <input asp-for="Telefono" class="form-control" />
                    <span asp-validation-for="Telefono" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="NumeroEmpleado" class="form-label"></label>
                    <input asp-for="NumeroEmpleado" class="form-control" />
                    <span asp-validation-for="NumeroEmpleado" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="EstadoCodigo" class="form-label"></label>
                    <select asp-for="EstadoCodigo" class="form-select">
                        <option value="ACTIVO">ACTIVO</option>
                        <option value="SUSPENDIDO">SUSPENDIDO</option>
                        <option value="INACTIVO">INACTIVO</option>
                    </select>
                    <span asp-validation-for="EstadoCodigo" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a href="@backUrl" class="btn btn-light">Cancelar</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
