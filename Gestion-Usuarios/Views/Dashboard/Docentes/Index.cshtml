@model List<Gestion_Usuarios.Models.DocenteViewModel>
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Gestión de Docentes";
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var isAdmin = User.HasAnyRole("ADMIN", "ADMINISTRADOR", "ADMINISTRATOR");
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 text-primary font-weight-bold">
            <i class="fa-solid fa-chalkboard-teacher me-2"></i>Listado de Docentes
        </h5>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-outline-secondary btn-sm">
                <i class="fa-solid fa-arrow-left me-1"></i>Menu
            </a>
            @if (isAdmin)
            {
                <a href="@Url.Action("Create", "Docentes", new { returnUrl = Context.Request.Path + Context.Request.QueryString })" class="btn btn-success btn-sm">
                    <i class="fa-solid fa-plus me-1"></i>Nuevo Docente
                </a>
            }
        </div>
    </div>
    <div class="card-body">
        @if (TempData["TeacherSuccess"] is string successMessage)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
            </div>
        }

        @if (TempData["TeacherError"] is string errorMessage)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
            </div>
        }

        <table id="tablaDocentes" class="table table-striped table-hover dt-responsive nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>No. Empleado</th>
                    <th>Nombre Completo</th>
                    @if (isAdmin)
                    {
                        <th>Correo</th>
                        <th>Teléfono</th>
                    }
                    <th>Estatus</th>
                    @if (isAdmin)
                    {
                        <th>Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var docente in Model)
                    {
                        <tr data-id="@docente.TeacherId">
                            <td><span class="badge bg-secondary">@docente.NumeroEmpleado</span></td>
                            <td>@docente.NombreCompleto</td>
                            @if (isAdmin)
                            {
                                <td>@docente.Email</td>
                                <td>@docente.Telefono</td>
                            }
                            <td>
                                <span class="badge @docente.BadgeClass">
                                    @(docente.Estado == "ACTIVO" ? "Activo" : docente.Estado)
                                </span>
                            </td>
                            @if (isAdmin)
                            {
                                <td>
                                    <button class="btn btn-primary btn-sm" onclick="editarDocente(@docente.TeacherId)" title="Editar">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>
                                    <button class="btn btn-danger btn-sm" onclick="eliminarDocente(@docente.TeacherId)" title="Desactivar">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaDocentes').DataTable({
                responsive: true,
                language: {
                    url: "https://cdn.datatables.net/plug-ins/2.0.0/i18n/es-ES.json"
                }
            });
        });

        function editarDocente(id) {
            if (!id) return;
            const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
            window.location.href = `@Url.Action("Edit", "Docentes")?id=${id}&returnUrl=${returnUrl}`;
        }

        function eliminarDocente(id) {
            if(confirm("¿Estás seguro de desactivar este docente?")) {
                fetch(`@Url.Action("Delete", "Docentes")/${id}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': '@token'
                    }
                }).then(async r => {
                    const data = await r.json().catch(() => ({}));
                    if(r.ok && data.success) location.reload();
                    else alert(data.message || "Error al procesar la solicitud");
                });
            }
        }
    </script>
}
