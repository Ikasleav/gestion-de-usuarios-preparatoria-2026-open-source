@model List<Gestion_Usuarios.Models.DocenteViewModel>
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Gesti¾n de Docentes";
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 text-primary font-weight-bold">
            <i class="fa-solid fa-chalkboard-teacher me-2"></i>Listado de Docentes
        </h5>
        <a href="@Url.Action("Create", "Docentes")" class="btn btn-success btn-sm">
            <i class="fa-solid fa-plus me-1"></i> Nuevo Docente
        </a>
    </div>
    <div class="card-body">
        <table id="tablaDocentes" class="table table-striped table-hover dt-responsive nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>No. Empleado</th>
                    <th>Nombre Completo</th>
                    <th>Correo</th>
                    <th>Telķfono</th>
                    <th>Estatus</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var docente in Model)
                    {
                        <tr data-id="@docente.UserId">
                            <td>
                                <span class="badge bg-secondary">@docente.NumeroEmpleado</span>
                            </td>
                            <td>@docente.NombreCompleto</td>
                            <td>@docente.Email</td>
                            <td>@docente.Telefono</td>
                            <td>
                                @* Usamos la propiedad calculada BadgeClass *@
                                <span class="badge @docente.BadgeClass">
                                    @(docente.Estado == "ACTIVO" ? "Activo" : docente.Estado)
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-primary btn-sm" onclick="editarDocente(@docente.UserId)" title="Editar">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                <button class="btn btn-danger btn-sm" onclick="eliminarDocente(@docente.UserId)" title="Desactivar">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaDocentes').DataTable({
                responsive: true,
                language: {
                    url: "https://cdn.datatables.net/plug-ins/2.0.0/i18n/es-ES.json"
                },
                columnDefs: [
                    { className: "text-center", targets: [0, 4, 5] },
                    { orderable: false, targets: 5 }
                ]
            });
        });

        function editarDocente(id) {
            if(id) window.location.href = `@Url.Action("Edit", "Docentes")/${id}`;
        }

        function eliminarDocente(id) {
            if(confirm("┐Estßs seguro de desactivar este docente?")) {
                fetch(`@Url.Action("Delete", "Docentes")/${id}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': '@token'
                    }
                }).then(r => {
                    if(r.ok) location.reload();
                    else alert("Error al procesar la solicitud");
                });
            }
        }
    </script>
}