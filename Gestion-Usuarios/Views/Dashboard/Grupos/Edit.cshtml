@model Gestion_Usuarios.Models.GroupEditViewModel
@{
    ViewData["Title"] = "Editar Grupo";
    var backUrl = Url.IsLocalUrl(Model.ReturnUrl) ? Model.ReturnUrl : Url.Action("Index", "Grupos");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1 text-primary">
            <i class="fa-solid fa-pen-to-square me-2"></i>Editar Grupo
        </h4>
        <p class="text-muted mb-0">Actualiza los datos principales del grupo.</p>
    </div>
    <a href="@backUrl" class="btn btn-outline-secondary btn-sm">
        <i class="fa-solid fa-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" asp-controller="Grupos" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="ReturnUrl" type="hidden" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            }

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CareerId" class="form-label"></label>
                    <select asp-for="CareerId" class="form-select">
                        <option value="">Sin carrera</option>
                        @foreach (var item in Model.CareerOptions)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label asp-for="Codigo" class="form-label"></label>
                    <input asp-for="Codigo" class="form-control" />
                    <span asp-validation-for="Codigo" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Turno" class="form-label"></label>
                    <input asp-for="Turno" class="form-control" />
                    <span asp-validation-for="Turno" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a href="@backUrl" class="btn btn-light">Cancelar</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
