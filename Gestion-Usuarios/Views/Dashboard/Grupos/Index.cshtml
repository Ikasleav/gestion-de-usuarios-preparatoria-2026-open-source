@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Gestión de Grupos";
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 text-primary font-weight-bold">
            <i class="fa-solid fa-object-group me-2"></i>Listado de Grupos
        </h5>
        <button class="btn btn-success btn-sm" onclick="nuevoGrupo()">
            <i class="fa-solid fa-plus me-1"></i> Nuevo Grupo
        </button>
    </div>
    <div class="card-body">
        <table id="tablaGrupos" class="table table-striped table-hover dt-responsive nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre Grupo</th>
                    <th>Código Estado</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @* Se llena via AJAX *@
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            window.dtGrupos = $('#tablaGrupos').DataTable({
                ajax: {
                    url: '@Url.Action("GetGrupos", "Grupos")',
                    type: 'GET',
                    dataSrc: 'data'
                },
                columns: [
                    { data: 'id' },
                    { data: 'nombre' },
                    { data: 'estadoCodigo' },
                    {
                        data: 'esActivo',
                        render: function(data, type, row) {
                            // Usamos la lógica de colores que definimos en GroupViewModel
                            const badgeClass = data ? 'bg-success' : 'bg-danger';
                            const text = data ? 'Activo' : 'Inactivo';
                            return `<span class="badge ${badgeClass}">${text}</span>`;
                        }
                    },
                    {
                        data: 'id',
                        orderable: false,
                        render: function(data, type, row) {
                            return `
                                <div class="btn-group">
                                    <button class="btn btn-outline-primary btn-sm" onclick="editarGrupo(${data})">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" onclick="eliminarGrupo(${data})">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>`;
                        }
                    }
                ],
                language: {
                    url: "https://cdn.datatables.net/plug-ins/2.0.0/i18n/es-ES.json"
                },
                responsive: true
            });
        });

        function editarGrupo(id) {
            console.log("Editando grupo:", id);
            // window.location.href = `@Url.Action("Edit", "Grupos")/${id}`;
        }

        function eliminarGrupo(id) {
            if (!confirm("żDeseas eliminar este grupo?")) return;

            fetch(`@Url.Action("Delete", "Grupos")/${id}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': '@token' }
            }).then(r => {
                if (r.ok) {
                    window.dtGrupos.ajax.reload(null, false); // Recarga sin perder la paginación
                } else {
                    alert("Error al eliminar el grupo");
                }
            });
        }

        function nuevoGrupo() {
            // Lógica para abrir modal o redirigir
        }
    </script>
}