@{
    ViewData["Title"] = "Bitácora de Usuarios";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white py-3">
        <h5 class="m-0"><i class="fa-solid fa-clock-rotate-left me-2"></i>Bitácora de Usuarios Registrados</h5>
    </div>
    <div class="card-body">
        <table id="tablaHistorial" class="table table-striped table-hover dt-responsive nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>Fecha Registro</th>
                    <th>Usuario</th>
                    <th>Nombre Completo</th>
                    <th>Email</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @* Llenado automático vía AJAX *@
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaHistorial').DataTable({
                "ajax": {
                    "url": "@Url.Action("GetHistorial", "Historicos")",
                    "type": "GET",
                    "dataSrc": "data"
                },
                "columns": [
                    {
                        "data": "fechaFormateada", // Usamos la propiedad calculada del ViewModel
                        "className": "text-center"
                    },
                    { "data": "usuario" },
                    { "data": "nombreCompleto" },
                    { "data": "email" },
                    {
                        "data": "esActivo",
                        "render": function(data, type, row) {
                            // Usamos el label que definimos en el ViewModel
                            const clase = data ? "badge bg-success" : "badge bg-danger";
                            const texto = data ? "Activo" : "Inactivo";
                            return `<span class="${clase}">${texto}</span>`;
                        }
                    }
                ],
                "order": [[0, 'desc']], // Los más recientes primero
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/2.0.0/i18n/es-ES.json"
                },
                "responsive": true,
                "dom": 'Bfrtip',
                "buttons": [
                    {
                        extend: 'excelHtml5',
                        className: 'btn btn-success btn-sm',
                        text: '<i class="fa-solid fa-file-excel"></i> Exportar Excel'
                    },
                    {
                        extend: 'pdfHtml5',
                        className: 'btn btn-danger btn-sm',
                        text: '<i class="fa-solid fa-file-pdf"></i> Generar PDF'
                    },
                    {
                        extend: 'print',
                        className: 'btn btn-info btn-sm',
                        text: '<i class="fa-solid fa-print"></i> Imprimir'
                    }
                ]
            });
        });
    </script>
}