@model Gestion_Usuarios.Models.UsuarioEditViewModel
@{
    ViewData["Title"] = "Registrar Usuario";
    var backUrl = Url.IsLocalUrl(Model.ReturnUrl) ? Model.ReturnUrl : Url.Action("Index", "Usuarios");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1 text-primary">
            <i class="fa-solid fa-user-plus me-2"></i>Registrar Usuario
        </h4>
        <p class="text-muted mb-0">Crea una cuenta de usuario con datos personales y rol.</p>
    </div>
    <a href="@backUrl" class="btn btn-outline-secondary btn-sm">
        <i class="fa-solid fa-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" asp-controller="Usuarios" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            }

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Username" class="form-label"></label>
                    <input asp-for="Username" class="form-control" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="RoleId" class="form-label"></label>
                    <select asp-for="RoleId" class="form-select">
                        <option value="">Selecciona un rol</option>
                        @foreach (var item in Model.RoleOptions)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>
                    <span asp-validation-for="RoleId" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="CareerId" class="form-label"></label>
                    <select asp-for="CareerId" class="form-select">
                        <option value="">Selecciona una carrera</option>
                        @foreach (var item in Model.CareerOptions)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>
                    <span asp-validation-for="CareerId" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="ApellidoPaterno" class="form-label"></label>
                    <input asp-for="ApellidoPaterno" class="form-control" />
                    <span asp-validation-for="ApellidoPaterno" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="ApellidoMaterno" class="form-label"></label>
                    <input asp-for="ApellidoMaterno" class="form-control" />
                    <span asp-validation-for="ApellidoMaterno" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="CURP" class="form-label"></label>
                    <input asp-for="CURP" class="form-control" maxlength="18" />
                    <span asp-validation-for="CURP" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Telefono" class="form-label"></label>
                    <input asp-for="Telefono" class="form-control" />
                    <span asp-validation-for="Telefono" class="text-danger small"></span>
                </div>

                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="IsLocked" class="form-check-input" />
                        <label asp-for="IsLocked" class="form-check-label">Bloquear al crear</label>
                    </div>
                </div>

                <div class="col-md-6">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" type="password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="col-md-12">
                    <label asp-for="LockReason" class="form-label"></label>
                    <input asp-for="LockReason" class="form-control" />
                    <span asp-validation-for="LockReason" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a href="@backUrl" class="btn btn-light">Cancelar</a>
                <button type="submit" class="btn btn-success">
                    <i class="fa-solid fa-plus me-1"></i>Registrar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
