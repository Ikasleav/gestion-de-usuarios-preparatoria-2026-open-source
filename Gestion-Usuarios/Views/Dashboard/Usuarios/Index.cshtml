@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Gestión de Usuarios";
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="m-0 font-weight-bold text-primary">
            <i class="fa-solid fa-users me-2"></i>Directorio General de Usuarios
        </h5>
        <a href="@Url.Action("Create", "Usuarios")" class="btn btn-success btn-sm">
            <i class="fa-solid fa-plus me-1"></i> Nuevo Usuario
        </a>
    </div>
    <div class="card-body">
        <table id="miTablaUsuarios" class="table table-striped table-hover dt-responsive nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>Identificador</th>
                    <th>Nombre Completo</th>
                    <th>Rol</th>
                    <th>Carrera / Depto</th>
                    <th>Grupo</th>
                    <th>Correo</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            window.dtUsuarios = $('#miTablaUsuarios').DataTable({
                responsive: true,
                ajax: {
                    url: '@Url.Action("GetUsersJson", "Usuarios")',
                    type: 'GET',
                    dataSrc: 'data'
                },
                columns: [
                    {
                        data: 'identificador',
                        render: function(data) {
                            return `<span class="fw-bold text-dark">${data || '---'}</span>`;
                        }
                    },
                    { data: 'nombreCompleto' },
                    {
                        data: 'roles',
                        render: function(data) {
                            let badgeClass = 'bg-secondary';
                            if (data && data.includes('ADMIN')) badgeClass = 'bg-dark';
                            else if (data && (data.includes('TEACHER') || data.includes('DOCENTE'))) badgeClass = 'bg-warning text-dark';
                            else if (data && (data.includes('STUDENT') || data.includes('ALUMNO'))) badgeClass = 'bg-info text-dark';

                            return `<span class="badge ${badgeClass}">${data}</span>`;
                        }
                    },
                    { data: 'carrera' },
                    { data: 'grupo' },
                    { data: 'correo' },
                    {
                        data: 'estado',
                        render: function(data) {
                            const estados = {
                                'INSCRITO': 'bg-success',
                                'ACTIVO': 'bg-success',
                                'PREINSCRITO': 'bg-info',
                                'BAJA': 'bg-danger',
                                'INACTIVO': 'bg-danger'
                            };
                            const clase = estados[data?.toUpperCase()] || 'bg-secondary';
                            return `<span class="badge ${clase}">${data}</span>`;
                        }
                    },
                    {
                        data: 'id',
                        orderable: false,
                        render: function (data) {
                            return `
                                <div class="btn-group">
                                    <button onclick="editarUsuario(${data})" class="btn btn-outline-primary btn-sm">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <button onclick="eliminarUsuario(${data})" class="btn btn-outline-danger btn-sm">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>`;
                        }
                    }
                ],
                language: { url: "https://cdn.datatables.net/plug-ins/2.0.0/i18n/es-ES.json" },
                dom: '<"d-flex justify-content-between"Bf>rtip',
                buttons: [
                    { extend: 'excel', className: 'btn btn-light btn-sm border', text: '<i class="fa-solid fa-file-excel text-success"></i>' },
                    { extend: 'pdf', className: 'btn btn-light btn-sm border', text: '<i class="fa-solid fa-file-pdf text-danger"></i>' }
                ]
            });
        });

        function editarUsuario(id) {
            window.location.href = `@Url.Action("Edit", "Usuarios")/${id}`;
        }

        function eliminarUsuario(id) {
            if (!confirm('¿Estás seguro de eliminar este usuario?')) return;

            fetch(`@Url.Action("Delete", "Usuarios")/${id}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': '@token' }
            }).then(r => {
                if (r.ok) window.dtUsuarios.ajax.reload(null, false);
                else alert("Error al eliminar");
            });
        }
    </script>
}